# Supply-chain hardening
# Block install lifecycle scripts (preinstall/postinstall) — the primary worm
# vector (Shai-Hulud, Miasma, Axios RAT all used them). All native deps in this
# project (esbuild, @parcel/watcher, sass-embedded, lightningcss) ship prebuilt
# binaries as optional dependencies, so nothing here needs install scripts.
ignore-scripts=true

# Refuse versions published less than 7 days ago (cooldown against freshly
# compromised releases). Requires npm >= 11.10.0; older npm warns and ignores.
min-release-age=7
